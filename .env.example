# ─── Aegis AutoDev Agency — Environment Variables ──────────────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ────────────────────────────────────────────────────────────────────────────

# REQUIRED — Your Groq API key (get one free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# REQUIRED for pushing to GitHub over HTTPS — Personal Access Token
# Create one at: https://github.com/settings/tokens
# Needs scope: repo (Full control of private repositories)
GITHUB_TOKEN=your_github_pat_here

# OPTIONAL — Override the default target repo folder name (default: ai-maintenance-demo)
# REPO_FOLDER=ai-maintenance-demo

# OPTIONAL — Override the target GitHub repository URL for pushes.
# If not set, the default target repo is the user's main repo.
# TARGET_REPO_URL=https://github.com/tanishamajumder23-cpu/ai-maintenance-demo.git
